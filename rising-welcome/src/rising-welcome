def check_internet(timeout=2.5) -> bool:
    try:
        socket.setdefaulttimeout(timeout)
        socket.socket(socket.AF_INET, socket.SOCK_STREAM).connect(("8.8.8.8", 53))
        return True
    except OSError:
        return False


def load_css():
    provider = Gtk.CssProvider()
    try:
        provider.load_from_path(CSS_FILE)
    except Exception as e:
        print(f"[WARN] CSS: {e}")
    Gtk.StyleContext.add_provider_for_display(
        Gdk.Display.get_default(),
        provider,
        Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
    )


def get_screen_size():
    display = Gdk.Display.get_default()
    monitor = display.get_monitors().get_item(0)
    geo = monitor.get_geometry()
    return geo.width, geo.height


def make_logo(size=80) -> Gtk.Image:
    img = Gtk.Image()
    img.add_css_class("logo-image")
    if os.path.exists(LOGO_256):
        img.set_from_file(LOGO_256)
        img.set_pixel_size(size)
    else:
        img.set_from_icon_name("system-run")
        img.set_pixel_size(size)
    return img


def make_monitor(screenshot_name: str) -> Gtk.Widget:
    outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    outer.add_css_class("monitor-frame-box")
    outer.set_halign(Gtk.Align.CENTER)
    outer.set_valign(Gtk.Align.CENTER)

    frame = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    frame.add_css_class("monitor-frame")

    img_path = os.path.join(SCREENS_DIR, f"{screenshot_name}.png")
    if os.path.exists(img_path):
        picture = Gtk.Picture.new_for_filename(img_path)
        picture.set_content_fit(Gtk.ContentFit.COVER)
        picture.add_css_class("monitor-screen")
        frame.append(picture)
    else:
        ph = Gtk.Label(label=f"[ {screenshot_name} ]")
        ph.add_css_class("monitor-screen")
        ph.add_css_class("screenshot-placeholder")
        ph.set_halign(Gtk.Align.CENTER)
        ph.set_valign(Gtk.Align.CENTER)
        frame.append(ph)

    stand_top  = Gtk.Box(); stand_top.add_css_class("monitor-stand-top");   stand_top.set_halign(Gtk.Align.CENTER)
    stand_base = Gtk.Box(); stand_base.add_css_class("monitor-stand-base"); stand_base.set_halign(Gtk.Align.CENTER)
    outer.append(frame)
    outer.append(stand_top)
    outer.append(stand_base)
    return outer


def left_panel(*widgets) -> Gtk.Box:
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=18)
    box.add_css_class("left-panel")
    box.set_valign(Gtk.Align.CENTER)
    for w in widgets:
        box.append(w)
    return box


def right_panel(child: Gtk.Widget) -> Gtk.Box:
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    box.add_css_class("right-panel")
    box.set_hexpand(True)
    box.set_halign(Gtk.Align.FILL)
    box.set_valign(Gtk.Align.FILL)
    child.set_halign(Gtk.Align.CENTER)
    child.set_valign(Gtk.Align.CENTER)
    box.append(child)
    return box


def make_tag(text):
