# ── Ventana principal ─────────────────────────────────────────────────────────

class WelcomeWindow(Gtk.ApplicationWindow):
    def __init__(self, app, has_internet: bool):
        super().__init__(application=app, title="Bienvenido a RisingOS")
        self.add_css_class("main-window")

        sw, sh = get_screen_size()
        win_w  = max(820, int(sw * 0.72))
        win_h  = max(520, int(sh * 0.72))
        self.set_default_size(win_w, win_h)
        self.set_resizable(True)

        self._cur = 0
        self._screens = [
            ScreenBienvenida(has_internet),
            ScreenActualizaciones(has_internet),
            ScreenTour(),
            ScreenPersonalizacion(),
            ScreenAplicaciones(),
            ScreenIA(),
            ScreenFinal(),
        ]
        self._total = len(self._screens)

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        root.add_css_class("root-box")

        self._stack = Gtk.Stack()
        self._stack.set_transition_type(Gtk.StackTransitionType.OVER_LEFT_RIGHT)
        self._stack.set_transition_duration(220)
        self._stack.set_vexpand(True)
        for i, s in enumerate(self._screens):
            self._stack.add_named(s, f"s{i}")
        self._stack.set_visible_child_name("s0")

        bottom = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        bottom.add_css_class("bottom-bar")

        self._btn_prev = Gtk.Button(label="← Anterior")
        self._btn_prev.add_css_class("btn-prev")
        self._btn_prev.set_sensitive(False)
        self._btn_prev.connect("clicked", self._prev)

        center = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        center.set_halign(Gtk.Align.CENTER)
        center.set_valign(Gtk.Align.CENTER)
        center.set_hexpand(True)

        self._dots_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=7)
        self._dots_row.set_halign(Gtk.Align.CENTER)
        self._dots = []
        for _ in range(self._total):
            d = Gtk.Box()
            d.add_css_class("progress-dot")
            self._dots.append(d)
            self._dots_row.append(d)

        self._step_lbl = Gtk.Label()
        self._step_lbl.add_css_class("step-label")
        center.append(self._dots_row)
        center.append(self._step_lbl)

        self._btn_next = Gtk.Button(label="Siguiente →")
        self._btn_next.add_css_class("btn-next")
        self._btn_next.connect("clicked", self._next)

        bottom.append(self._btn_prev)
        bottom.append(center)
        bottom.append(self._btn_next)

        root.append(self._stack)
        root.append(bottom)
        self.set_child(root)
        self._refresh()

    def _refresh(self):
        i, n = self._cur, self._total
        self._btn_prev.set_sensitive(i > 0)
        self._btn_next.set_label("Cerrar  ✓" if i == n - 1 else "Siguiente →")
        self._step_lbl.set_label(f"{i+1} / {n}")
        for j, d in enumerate(self._dots):
            d.remove_css_class("dot-active")
            d.remove_css_class("dot-visited")
            if j == i:   d.add_css_class("dot-active")
            elif j < i:  d.add_css_class("dot-visited")

    def _prev(self, *_):
        if self._cur > 0:
            self._cur -= 1
            self._stack.set_transition_type(Gtk.StackTransitionType.OVER_RIGHT_LEFT)
            self._stack.set_visible_child_name(f"s{self._cur}")
            self._refresh()

    def _next(self, *_):
        if self._cur < self._total - 1:
            self._cur += 1
            self._stack.set_transition_type(Gtk.StackTransitionType.OVER_LEFT_RIGHT)
            self._stack.set_visible_child_name(f"s{self._cur}")
            self._refresh()
        else:
            final: ScreenFinal = self._screens[-1]
            if final.should_dismiss():
                os.makedirs(os.path.dirname(DISMISS_FLAG), exist_ok=True)
                open(DISMISS_FLAG, "w").write("dismissed\n")
            self.get_application().quit()


# ── App ───────────────────────────────────────────────────────────────────────

class WelcomeApp(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="ar.risingarrow.risingos.welcome")

    def do_activate(self):
        load_css()
        has_internet = check_internet()
        WelcomeWindow(self, has_internet).present()


def main():
    if os.path.exists(DISMISS_FLAG):
        sys.exit(0)
    WelcomeApp().run(sys.argv)


if __name__ == "__main__":
    main()
