    def _build_terminal_widget(self) -> Gtk.Widget:
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        outer.add_css_class("fake-terminal")
        outer.set_size_request(400, 300)

        titlebar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        titlebar.add_css_class("fake-terminal-bar")
        for _ in ["#ff5f56", "#ffbd2e", "#27c93f"]:
            dot = Gtk.Box()
            dot.add_css_class("terminal-dot")
            dot.set_size_request(10, 10)
            titlebar.append(dot)
        title_lbl = Gtk.Label(label="Terminal")
        title_lbl.add_css_class("terminal-title")
        title_lbl.set_hexpand(True)
        titlebar.append(title_lbl)
        outer.append(titlebar)

        buf = Gtk.TextBuffer()
        lines = [
            ("prompt",  "usuario@risingos:~$ "),
            ("cmd",     "sudo apt update && apt upgrade -y\n"),
            ("muted",   "Obj:1 http://deb.debian.org/debian trixie InRelease\n"),
            ("muted",   "Des:2 http://security.debian.org trixie-security/main\n"),
            ("muted",   "Des:3 http://deb.debian.org/debian trixie/main amd64\n"),
            ("ok",      "Leyendo lista de paquetes... Hecho\n"),
            ("ok",      "Analizando arbol de dependencias... Hecho\n"),
            ("muted",   "Los siguientes paquetes seran actualizados:\n"),
            ("accent",  "  linux-image-6.12  xfce4-panel  firefox-esr\n"),
            ("accent",  "  libc6  libssl3  xfwm4  thunar  libgtk-4-1\n"),
            ("muted",   "8 actualizados, 0 nuevos, 0 para eliminar.\n"),
            ("muted",   "\nDescargando: firefox-esr 128.5.0\n"),
            ("bar",     "63%  ################......  38.4 MB/s\n"),
            ("warn",    "\n¿Desea continuar? [S/n] "),
            ("accent",  "S"),
        ]
        tag_map = {
            "prompt": buf.create_tag("prompt", foreground="rgba(255,255,255,0.35)", family="monospace", size_points=9),
            "cmd":    buf.create_tag("cmd",    foreground="#ff6a3d",                family="monospace", size_points=9),
            "muted":  buf.create_tag("muted",  foreground="rgba(255,255,255,0.25)", family="monospace", size_points=9),
            "ok":     buf.create_tag("ok",     foreground="#27c93f",                family="monospace", size_points=9),
            "accent": buf.create_tag("accent", foreground="#ff6a3d",                family="monospace", size_points=9),
            "bar":    buf.create_tag("bar",    foreground="rgba(255,255,255,0.3)",  family="monospace", size_points=9),
            "warn":   buf.create_tag("warn",   foreground="rgba(255,189,46,0.8)",   family="monospace", size_points=9),
        }
        for tag_name, text in lines:
            buf.insert_with_tags(buf.get_end_iter(), text, tag_map[tag_name])

        tv = Gtk.TextView(buffer=buf)
        tv.set_editable(False); tv.set_cursor_visible(False); tv.set_monospace(True)
        tv.add_css_class("terminal-content"); tv.set_vexpand(True)
        scroll = Gtk.ScrolledWindow()
        scroll.set_child(tv); scroll.set_vexpand(True)
        scroll.add_css_class("terminal-scroll")
        outer.append(scroll)
        return outer

    def _append_log(self, text: str):
        self._log_buf.insert(self._log_buf.get_end_iter(), text)
        adj = self._log_scroll.get_vadjustment()
        GLib.idle_add(adj.set_value, adj.get_upper())

    def _on_click(self, btn):
        if self._updating: return
        self._updating = True
        btn.set_sensitive(False)
        btn.set_label("Actualizando...")
        self._progress.set_visible(True)
        self._log_buf.set_text("")
        self._right_stack.set_visible_child_name("log")
        GLib.timeout_add(120, self._pulse)
        threading.Thread(target=self._run_update, daemon=True).start()

    def _pulse(self):
        self._progress.pulse()
        return self._updating

    def _run_update(self):
        ok = True
        for cmd in [["pkexec", "apt-get", "-y", "update"], ["pkexec", "apt-get", "-y", "upgrade"]]:
            try:
                proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, bufsize=1)
                for line in proc.stdout:
                    GLib.idle_add(self._append_log, line)
                proc.wait(timeout=300)
                if proc.returncode not in (0, None):
                    ok = False; break
            except Exception as e:
                GLib.idle_add(self._append_log, f"Error: {e}\n")
                ok = False; break
        GLib.idle_add(self._finish, ok)

    def _finish(self, ok: bool):
        self._updating = False
        self._progress.set_visible(False)
        if ok:
            self._btn.set_label("✓  Sistema actualizado")
            self._btn.remove_css_class("btn-action")
            self._btn.add_css_class("btn-action-ok")
            self._status.set_label("Tu sistema está al día.")
            self._status.add_css_class("status-ok")
        else:
            self._btn.set_label("Reintentar")
            self._btn.set_sensitive(True)
            self._status.set_label("Ocurrió un error. Podés intentarlo más tarde.")
            self._status.add_css_class("status-fail")


